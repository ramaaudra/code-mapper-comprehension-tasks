<file path="src/lib/cluster.ts">
export type Cluster = {
  id: string;           // e.g. "components" or "pages/admin"
  label: string;        // label to display
  nodes: string[];      // list of node ids (file absolute paths)
  depth: number;        // number of path segments
  color?: string;       // optional cluster color for theming
};

export interface ClusterOptions {
  depth?: number;       // path segments to use for clustering (1-3)
  minSize?: number;     // minimum nodes per cluster (2-5)
}

/**
 * Build clusters from node labels by grouping files with shared path prefixes
 * @param labels Array of {id, pathLabel} where pathLabel is relative path
 * @param options Clustering configuration
 * @returns Array of clusters sorted by id
 */
export function buildClusters(
  labels: { id: string; pathLabel: string }[], 
  options: ClusterOptions = {}
): Cluster[] {
  const { depth = 1, minSize = 2 } = options;
  
  // Group nodes by path prefix
  const groupMap = new Map<string, string[]>();
  
  for (const item of labels) {
    // Skip if path doesn't have enough segments
    const segments = item.pathLabel.split('/').filter(s => s.length > 0);
    if (segments.length < depth) continue;
    
    // Create cluster key from first N segments
    const key = segments.slice(0, depth).join('/');
    const existing = groupMap.get(key) || [];
    existing.push(item.id);
    groupMap.set(key, existing);
  }
  
  // Filter clusters by minimum size and create cluster objects
  const clusters: Cluster[] = [];
  const clusterColors = [
    '#E3F2FD', '#F3E5F5', '#E8F5E8', '#FFF3E0', 
    '#FCE4EC', '#E1F5FE', '#F1F8E9', '#FFF8E1'
  ];
  
  let colorIndex = 0;
  for (const [key, nodeIds] of groupMap) {
    if (nodeIds.length >= minSize) {
      clusters.push({
        id: key,
        label: key,
        nodes: nodeIds,
        depth,
        color: clusterColors[colorIndex % clusterColors.length]
      });
      colorIndex++;
    }
  }
  
  return clusters.sort((a, b) => a.id.localeCompare(b.id));
}

/**
 * Create a mapping from node ID to cluster ID
 * @param clusters Array of clusters
 * @returns Record mapping node ID to cluster ID
 */
export function createNodeClusterMap(clusters: Cluster[]): Record<string, string> {
  const nodeToCluster: Record<string, string> = {};
  
  for (const cluster of clusters) {
    for (const nodeId of cluster.nodes) {
      nodeToCluster[nodeId] = cluster.id;
    }
  }
  
  return nodeToCluster;
}

/**
 * Get nodes that don't belong to any cluster (orphaned nodes)
 * @param allNodeIds All node IDs in the graph
 * @param nodeToCluster Mapping from node ID to cluster ID
 * @returns Array of unclustered node IDs
 */
export function getUnclusteredNodes(
  allNodeIds: string[], 
  nodeToCluster: Record<string, string>
): string[] {
  return allNodeIds.filter(id => !nodeToCluster[id]);
}

/**
 * Calculate statistics about clustering
 * @param clusters Array of clusters
 * @param totalNodes Total number of nodes
 * @returns Clustering statistics
 */
export function getClusteringStats(clusters: Cluster[], totalNodes: number) {
  const clusteredNodes = clusters.reduce((sum, c) => sum + c.nodes.length, 0);
  const orphanedNodes = totalNodes - clusteredNodes;
  const clusterSizes = clusters.map(c => c.nodes.length);
  
  return {
    clusterCount: clusters.length,
    clusteredNodes,
    orphanedNodes,
    clusteringRatio: clusteredNodes / totalNodes,
    averageClusterSize: clusteredNodes / (clusters.length || 1),
    largestCluster: clusterSizes.length > 0 ? Math.max(...clusterSizes) : 0,
    smallestCluster: clusterSizes.length > 0 ? Math.min(...clusterSizes) : 0,
    // Additional metrics for adaptive recommendations
    efficiency: clusteredNodes / totalNodes,
    clusterSizeDistribution: {
      small: clusterSizes.filter(s => s <= 3).length,
      medium: clusterSizes.filter(s => s > 3 && s <= 8).length,
      large: clusterSizes.filter(s => s > 8).length
    }
  };
}
