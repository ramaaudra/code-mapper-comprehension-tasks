  const [useClustering, setUseClustering] = useState(false);
  const [clusterDepth, setClusterDepth] = useState(1);
  const [clusterMinSize, setClusterMinSize] = useState(2);
  const [clusteringStats, setClusteringStats] = useState<any>(null);
  
  // Focus subgraph state
  const [focusedSubgraph, setFocusedSubgraph] = useState<{
    nodeId: string;
    direction: 'inward' | 'outward';
    filteredData: any;
  } | null>(null);
  
  const handleFocusSubgraph = (nodeId: string, direction: 'inward' | 'outward') => {
    if (!data) return;
    
    // Get all relevant nodes and edges for the subgraph
    const relevantNodes = new Set<string>();
    const relevantEdges = new Set<string>();
    
    // Add the central node
    relevantNodes.add(nodeId);
    
    if (direction === 'outward') {
      // Find all nodes that this node depends on (outgoing edges)
      const findOutgoing = (currentId: string, depth = 0) => {
        if (depth > 3) return; // Limit depth to prevent infinite recursion
        
        data.edges.forEach((edge: any) => {
          if (edge.source === currentId) {
            relevantNodes.add(edge.target);
            relevantEdges.add(`${edge.source}->${edge.target}`);
            findOutgoing(edge.target, depth + 1);
          }
        });
      };
      findOutgoing(nodeId);
    } else {
      // Find all nodes that depend on this node (incoming edges)
      const findIncoming = (currentId: string, depth = 0) => {
        if (depth > 3) return; // Limit depth to prevent infinite recursion
        
        data.edges.forEach((edge: any) => {
          if (edge.target === currentId) {
            relevantNodes.add(edge.source);
            relevantEdges.add(`${edge.source}->${edge.target}`);
            findIncoming(edge.source, depth + 1);
          }
        });
      };
      findIncoming(nodeId);
    }
    
    // Filter data to only include relevant nodes and edges
    const filteredData = {
      ...data,
      nodes: data.nodes.filter((node: any) => relevantNodes.has(node.id)),
      edges: data.edges.filter((edge: any) => 
        relevantEdges.has(`${edge.source}->${edge.target}`)
      )
    };
    
    setFocusedSubgraph({
      nodeId,
      direction,
      filteredData
    });
  };
  
  const clearFocusSubgraph = () => {
    setFocusedSubgraph(null);
  };
  
  const run = async () => {
    try {
      setIsAnalyzing(true);
      const result = await analyzeProject({ rootPath });
      setData(result);
      setFocusedSubgraph(null); // Clear focus when new data is loaded
      setSelectedNode(null); // Clear selected node
    } catch (error) {
      console.error('Analysis failed:', error);
    } finally {
      setIsAnalyzing(false);
    }
  };
  
  const toggleTheme = () => {
    setTheme(theme === 'light' ? 'dark' : 'light');
  };
  
  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-950">
      {/* Simple Top Bar */}
      <div className="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 p-4">
        <div className="max-w-7xl mx-auto flex items-center justify-between">
          {/* Left: Title */}
          <div className="flex items-center gap-3">
            <div className="w-8 h-8 bg-gradient-to-r from-blue-500 to-purple-600 rounded-lg flex items-center justify-center">
              <div className="w-4 h-4 bg-white rounded-sm opacity-90"></div>
            </div>
            <h1 className="text-xl font-bold text-slate-800 dark:text-slate-100">
              Code Mapper
            </h1>
          </div>
          
          {/* Center: Input and Analyze */}
          <div className="flex items-center gap-3">
            <div className="relative">
              <Input
                value={rootPath}
                onChange={e => setRootPath(e.target.value)}
                placeholder="Enter project path..."
                className="w-80 pr-4 border-slate-300 dark:border-slate-600 focus:border-blue-500 dark:focus:border-blue-400"
              />
            </div>
            <Button 
              onClick={run}
              disabled={isAnalyzing}
              className="bg-blue-600 hover:bg-blue-700 text-white px-6"
            >
              {isAnalyzing ? (
                <>
                  <div className="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2"></div>
                  Analyzing...
                </>
              ) : (
                <>
                  <Play className="h-4 w-4 mr-2" />
                  Analyze
                </>
              )}
            </Button>
          </div>
          
          {/* Right: Search and Theme */}
          <div className="flex items-center gap-3">
            {data && (
              <div className="relative">
                <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 h-4 w-4 text-slate-400" />
                <Input
                  value={query}
                  onChange={e => setQuery(e.target.value)}
                  placeholder="Search files..."
                  className="pl-10 w-48 border-slate-300 dark:border-slate-600 focus:border-blue-500 dark:focus:border-blue-400"
                />
              </div>
            )}
            <Button
              variant="ghost"
              size="icon"
              onClick={toggleTheme}
              className="text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800"
            >
              {theme === 'light' ? 
                <Moon className="h-5 w-5" /> : 
                <Sun className="h-5 w-5" />
              }
            </Button>
          </div>
        </div>
      </div>
      
      {/* Stats Bar */}
      {data && (
        <div className="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 px-4 py-2">
          <div className="max-w-7xl mx-auto flex items-center justify-between text-sm text-slate-600 dark:text-slate-400">
            <div className="flex items-center gap-6">
              {focusedSubgraph ? (
                <>
                  <span className="px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-full text-xs font-medium">
                    🎯 Focused on {focusedSubgraph.direction === 'inward' ? 'Dependencies' : 'Dependents'}
                  </span>
                  <span><strong className="text-slate-900 dark:text-slate-100">{focusedSubgraph.filteredData.nodes?.length || 0}</strong> files</span>
                  <span><strong className="text-slate-900 dark:text-slate-100">{focusedSubgraph.filteredData.edges?.length || 0}</strong> dependencies</span>
                  <Button 
                    variant="ghost" 
                    size="sm" 
                    onClick={clearFocusSubgraph}
                    className="h-6 px-2 text-xs text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
                  >
                    Clear Focus
                  </Button>
                </>
              ) : (
                <>
                  <span><strong className="text-slate-900 dark:text-slate-100">{data.nodes?.length || 0}</strong> files</span>
                  <span><strong className="text-slate-900 dark:text-slate-100">{data.edges?.length || 0}</strong> dependencies</span>
                  {data.metrics?.circularDependencies?.length > 0 && (
                    <span className="text-red-600 dark:text-red-400">
                      <strong>{data.metrics.circularDependencies.length}</strong> circular deps
                    </span>
                  )}
                  {data.metrics?.orphans?.length > 0 && (
                    <span className="text-yellow-600 dark:text-yellow-400">
                      <strong>{data.metrics.orphans.length}</strong> orphan files
                    </span>
                  )}
                </>
              )}
            </div>
            <div className="text-xs">
              Analyzed: <strong>{new Date().toLocaleTimeString()}</strong>
            </div>
          </div>
        </div>
      )}
      
      {/* Main Graph Area */}
      <div className={`h-[calc(100vh-140px)] ${selectedNode ? 'mr-96' : ''} transition-all duration-300 relative`}>
        {data ? (
          <ReactFlowProvider>
            <GraphView 
              ref={graphViewRef}
              data={focusedSubgraph ? focusedSubgraph.filteredData : data} 
              query={query} 
              showDynamicImports={showDynamicImports}
              onNodeClick={setSelectedNode}
              direction={direction}
              ranksep={ranksep}
              nodesep={nodesep}
              useClustering={useClustering && !focusedSubgraph} // Disable clustering in focus mode
              clusterDepth={clusterDepth}
              clusterMinSize={clusterMinSize}
              onClusteringStatsChange={setClusteringStats}
            />
            <LayoutControls
              direction={direction}
              onDirectionChange={setDirection}
              ranksep={ranksep}
              onRanksepChange={setRanksep}
              nodesep={nodesep}
              onNodesepChange={setNodesep}
              showDynamicImports={showDynamicImports}
              onShowDynamicImportsChange={setShowDynamicImports}
              onFitView={() => graphViewRef.current?.fitView()}
              useClustering={useClustering}
              onUseClusteringChange={setUseClustering}
              clusterDepth={clusterDepth}
              onClusterDepthChange={setClusterDepth}
              clusterMinSize={clusterMinSize}
              onClusterMinSizeChange={setClusterMinSize}
              clusteringStats={clusteringStats}
            />
          </ReactFlowProvider>
        ) : (
          <div className="h-full flex items-center justify-center">
            <div className="text-center">
              <div className="w-24 h-24 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-4 opacity-20">
                <div className="w-12 h-12 bg-white rounded-full opacity-90"></div>
              </div>
              <h2 className="text-xl font-semibold text-slate-700 dark:text-slate-300 mb-2">
                Ready to analyze your codebase
              </h2>
              <p className="text-slate-500 dark:text-slate-400">
                Enter a project path above and click "Analyze" to get started
              </p>
            </div>
          </div>
        )}
      </div>
      
      {/* Node Detail Panel */}
      {selectedNode && (
        <NodeDetailPanel 
          node={selectedNode}
          data={focusedSubgraph ? focusedSubgraph.filteredData : data}
          onClose={() => setSelectedNode(null)}
          onFocusSubgraph={handleFocusSubgraph}
        />
      )}
    </div>
  );
}

export default function App() {
  return (
    <ThemeProvider defaultTheme="system" storageKey="code-mapper-theme">
      <AppContent />
    </ThemeProvider>
  );
}
</file>

