}

/**
 * Analyze clustering statistics and provide adaptive recommendations
 * @param stats Clustering statistics
 * @param currentMinSize Current minimum cluster size setting
 * @returns Recommendation object with message and optional action
 */
function getClusteringRecommendation(
  stats: {
    clusterCount: number;
    clusteredNodes: number;
    orphanedNodes: number;
    clusteringRatio?: number;
    averageClusterSize?: number;
    largestCluster?: number;
    smallestCluster?: number;
  },
  currentMinSize: number
) {
  const totalNodes = stats.clusteredNodes + stats.orphanedNodes;
  const efficiency = stats.clusteredNodes / totalNodes;
  
  // Low clustering efficiency (< 30%)
  if (efficiency < 0.3 && currentMinSize > 2) {
    return {
      message: `Only ${Math.round(efficiency * 100)}% of files are grouped. Lower min size to create more folders.`,
      action: {
        type: 'adjust-minsize',
        value: Math.max(2, currentMinSize - 1),
        label: `Try ${Math.max(2, currentMinSize - 1)} files`
      }
    };
  }
  
  // Too many small clusters (efficiency > 80% but many clusters)
  if (efficiency > 0.8 && stats.clusterCount > totalNodes * 0.4 && currentMinSize < 5) {
    return {
      message: `${stats.clusterCount} folders created - may be too granular. Increase min size for cleaner grouping.`,
      action: {
        type: 'adjust-minsize',
        value: Math.min(8, currentMinSize + 1),
        label: `Try ${Math.min(8, currentMinSize + 1)} files`
      }
    };
  }
  
  // Good clustering
  if (efficiency >= 0.5 && efficiency <= 0.8) {
    return {
      message: `Good clustering balance - ${Math.round(efficiency * 100)}% grouped in ${stats.clusterCount} folders.`
    };
  }
  
  // Very low clustering with high minSize
  if (stats.clusterCount === 0 && currentMinSize >= 4) {
    return {
      message: 'No folders created. Your project may have a flat structure.',
      action: {
        type: 'adjust-minsize',
        value: 2,
        label: 'Try 2 files'
      }
    };
  }
  
  return null;
}
