              />
            </div>
          </Card>

          {/* Reset and Actions */}
          <Card className="p-4">
            <h3 className="text-sm font-medium mb-3">Actions</h3>
            
            <div className="space-y-2">
              <Button
                variant="outline"
                size="sm"
                onClick={onFitView}
                className="w-full flex items-center gap-2"
              >
