import type { Edge, Node } from 'reactflow';
import { MarkerType } from 'reactflow';
import { layoutGraph } from './layout';
import { buildClusters, createNodeClusterMap, getUnclusteredNodes, type ClusterOptions } from './cluster';
import { type LayoutOptions, DEFAULT_LAYOUT } from '@/config/layout';

export interface ClusterLayoutOptions extends ClusterOptions {
  padding?: number;     // padding inside cluster containers
  gap?: number;         // gap between clusters in meta-layout
  layoutOptions?: LayoutOptions;  // layout options for individual clusters and meta-graph
}

/**
 * Layout nodes using folder-based clustering
 * Groups nodes by folder structure, layouts each cluster separately,
 * then layouts clusters in a meta-graph
 * This version avoids React Flow's parent-child system to prevent recursion issues
 */
export function layoutWithClusters(
  baseNodes: Node[],
  baseEdges: Edge[],
  pathLabels: Record<string, string>, // nodeId -> relative path
  options: ClusterLayoutOptions = {}
): { nodes: Node[]; edges: Edge[] } {
  const {
    depth = 1,
    minSize = 2,
    padding = 24,
    gap = 120,
    layoutOptions = DEFAULT_LAYOUT
  } = options;

  // 1) Build clusters from path labels
  const labels = baseNodes.map(n => ({
    id: n.id,
    pathLabel: pathLabels[n.id] || n.data?.label || ''
  }));
  
  const clusters = buildClusters(labels, { depth, minSize });
  const nodeToCluster = createNodeClusterMap(clusters);

  // 2) Handle case with no clusters or unsafe conditions (fallback to regular layout)
  if (clusters.length === 0 || baseNodes.length > 200) {
    console.log('Clustering disabled: no clusters or too many nodes for safe clustering');
    return layoutGraph(baseNodes, baseEdges, layoutOptions);
  }

  // Additional safety check: ensure no nodes already have parent relationships
  const hasExistingParents = baseNodes.some(n => n.parentNode || n.data?.parentId);
  if (hasExistingParents) {
    console.log('Clustering disabled: existing parent relationships detected');
    return layoutGraph(baseNodes, baseEdges, layoutOptions);
  }

  // 3) Layout each cluster internally
  const containerNodes: Node[] = [];
  const clusterChildren: Node[] = [];

  for (const cluster of clusters) {
    // Get nodes and edges within this cluster
    const clusterNodes = baseNodes.filter(n => nodeToCluster[n.id] === cluster.id);
    const clusterEdges = baseEdges.filter(e => 
      nodeToCluster[e.source] === cluster.id && nodeToCluster[e.target] === cluster.id
    );

    if (clusterNodes.length === 0) continue;

    // Layout nodes within cluster
    const internalLayout = layoutGraph(clusterNodes, clusterEdges, {
      ...layoutOptions,
      direction: 'TB', // Use top-bottom for internal cluster layout
      ranksep: Math.max(40, (layoutOptions.ranksep ?? DEFAULT_LAYOUT.ranksep) / 2),
      nodesep: Math.max(30, (layoutOptions.nodesep ?? DEFAULT_LAYOUT.nodesep) / 2)
    });

    // Calculate bounding box of laid out cluster
    const positions = internalLayout.nodes.map(n => n.position);
    const widths = internalLayout.nodes.map(n => n.width ?? 160);
    const heights = internalLayout.nodes.map(n => n.height ?? 48);
    
    const xs = positions.map(p => p.x);
    const ys = positions.map(p => p.y);
    const maxXs = positions.map((p, i) => p.x + widths[i]);
    const maxYs = positions.map((p, i) => p.y + heights[i]);

    const minX = Math.min(...xs);
    const minY = Math.min(...ys);
    const maxX = Math.max(...maxXs);
    const maxY = Math.max(...maxYs);

    const clusterWidth = (maxX - minX) + padding * 2;
    const clusterHeight = (maxY - minY) + padding * 2;

    // Store child nodes with their relative positions (we'll position them absolutely later)
    const normalizedChildren = internalLayout.nodes.map(n => ({
      ...n,
      position: {
        x: (n.position.x - minX) + padding,
        y: (n.position.y - minY) + padding
      },
      // Add cluster metadata but don't use React Flow's parentNode system
      data: {
        ...n.data,
        clusterId: cluster.id,
        isChildNode: true
      },
      style: {
        ...n.style,
        zIndex: 10 // Ensure child nodes appear above containers
      }
    }));

    clusterChildren.push(...normalizedChildren);

    // Create container node for this cluster
    containerNodes.push({
      id: cluster.id,
      type: 'group',
      data: {
        label: cluster.label,
        width: clusterWidth,
        height: clusterHeight,
        nodeCount: clusterNodes.length,
        color: cluster.color
      },
      position: { x: 0, y: 0 }, // Will be positioned by meta-layout
      style: {
        width: clusterWidth,
        height: clusterHeight,
        padding: 0,
        borderRadius: 16,
        border: '2px solid #e2e8f0',
        backgroundColor: cluster.color || '#f8fafc',
        opacity: 0.9,
        zIndex: 1 // Container nodes behind child nodes
      },
      width: clusterWidth,
      height: clusterHeight,
      selectable: true,
      draggable: true
    });
  }

  // 4) Build meta-graph: edges between clusters
  const metaEdges: Edge[] = [];
  const addedMetaEdges = new Set<string>();

  for (const edge of baseEdges) {
    const sourceCluster = nodeToCluster[edge.source];
    const targetCluster = nodeToCluster[edge.target];
    
    if (sourceCluster && targetCluster && sourceCluster !== targetCluster) {
      const metaEdgeId = `${sourceCluster}->${targetCluster}`;
      
      if (!addedMetaEdges.has(metaEdgeId)) {
        metaEdges.push({
          id: metaEdgeId,
          source: sourceCluster,
          target: targetCluster,
          type: 'smoothstep',
          style: {
            stroke: '#94a3b8',
            strokeWidth: 3,
            opacity: 0.7
          },
          markerEnd: { type: MarkerType.ArrowClosed }
        });
        addedMetaEdges.add(metaEdgeId);
      }
    }
  }

  // 5) Layout clusters in meta-graph
  const metaLayoutOptions = {
    ...layoutOptions,
    direction: layoutOptions.direction, // Use user's preferred direction for clusters
    ranksep: gap,
    nodesep: gap / 2
  };

  const metaLayout = layoutGraph(containerNodes, metaEdges, metaLayoutOptions);

  // 6) Apply cluster positions to child nodes
  const clusterPositions = new Map(
    metaLayout.nodes.map(n => [n.id, n.position])
  );

  const finalChildren = clusterChildren.map(child => {
    const clusterId = child.data?.clusterId;
    if (!clusterId) return child;
    
    const clusterPos = clusterPositions.get(clusterId);
    if (!clusterPos) return child;

    return {
      ...child,
      position: {
        x: clusterPos.x + child.position.x,
        y: clusterPos.y + child.position.y
      }
    };
  });

  // 7) Handle unclustered (orphan) nodes
  const orphanNodeIds = getUnclusteredNodes(
    baseNodes.map(n => n.id),
    nodeToCluster
  );
  
  const orphanNodes = baseNodes.filter(n => orphanNodeIds.includes(n.id));
  const orphanEdges = baseEdges.filter(e =>
    orphanNodeIds.includes(e.source) && orphanNodeIds.includes(e.target)
  );

  let positionedOrphans: Node[] = [];
  if (orphanNodes.length > 0) {
    const orphanLayout = layoutGraph(orphanNodes, orphanEdges, {
      ...layoutOptions,
      direction: 'TB'
    });

    // Position orphans below the clustered content
    const maxY = metaLayout.nodes.length > 0 
      ? Math.max(...metaLayout.nodes.map(n => (n.position.y + (n.height ?? 0))))
      : 0;
    
    const orphanStartY = maxY + gap;

    positionedOrphans = orphanLayout.nodes.map(n => ({
      ...n,
      position: {
        x: n.position.x,
        y: n.position.y + orphanStartY
      }
    }));
  }

  // 8) Combine all nodes and preserve original edges
  const allNodes = [
    ...metaLayout.nodes,      // Cluster container nodes
    ...finalChildren,         // Child nodes within clusters
    ...positionedOrphans      // Unclustered nodes
  ];

  return {
    nodes: allNodes,
    edges: baseEdges // Keep original edges for proper connections
  };
}

/**
 * Check if clustering would be beneficial for the given data
 * @param pathLabels Record of nodeId -> relative path
 * @param options Clustering options
 * @returns True if clustering would create meaningful groups
 */
export function shouldUseClustering(
  pathLabels: Record<string, string>,
  options: ClusterOptions = {}
): boolean {
  const labels = Object.entries(pathLabels).map(([id, pathLabel]) => ({ id, pathLabel }));
  const clusters = buildClusters(labels, options);
  
  // Only use clustering if we get meaningful groups
  const totalNodes = labels.length;
  const clusteredNodes = clusters.reduce((sum, c) => sum + c.nodes.length, 0);
  const clusteringRatio = clusteredNodes / totalNodes;
  
  return clusters.length > 1 && clusteringRatio >= 0.3; // At least 30% of nodes should be clustered
}
