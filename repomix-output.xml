import { memo } from 'react';
import { Handle, Position, type NodeProps } from 'reactflow';
import { Folder, Files, ChevronDown, ChevronRight } from 'lucide-react';

interface GroupNodeData {
  label: string;
  width?: number;
  height?: number;
  nodeCount: number;
  color?: string;
  isBackground?: boolean;
  clusterId?: string;
  collapsedNodes?: string[];
  isCollapsed?: boolean;
}

const GroupNode = memo(function GroupNode({ data, selected }: NodeProps<GroupNodeData>) {
  const { label, nodeCount, color = '#f8fafc', isBackground = false, collapsedNodes, isCollapsed = false } = data;
  const actuallyCollapsed = isCollapsed || Boolean(collapsedNodes && collapsedNodes.length > 0);
  
  // Background nodes are just visual containers
  if (isBackground) {
    return (
      <div
        className="rounded-2xl border border-slate-300/30 dark:border-slate-600/30 bg-opacity-20"
        style={{
          backgroundColor: color,
          width: '100%',
          height: '100%',
          minWidth: '160px',
          minHeight: '120px'
        }}
      >
        {/* Simple header for background */}
        <div className="px-3 py-2 text-xs font-medium text-slate-600 dark:text-slate-400 opacity-70 border-b border-slate-200/30 dark:border-slate-600/30">
          📁 {label} ({nodeCount})
        </div>
      </div>
    );
  }

  // Interactive cluster nodes
  return (
    <div
      className={`
        rounded-2xl border-2 backdrop-blur-sm
        transition-all duration-200 relative overflow-hidden cursor-pointer
        hover:shadow-lg hover:scale-[1.02] active:scale-[0.98]
        ${actuallyCollapsed 
          ? 'bg-slate-50/90 dark:bg-slate-800/90 border-slate-400 dark:border-slate-500' 
          : 'bg-white/50 dark:bg-slate-900/50 border-slate-300 dark:border-slate-600'
        }
        ${selected 
          ? 'border-blue-500 shadow-lg shadow-blue-200/50 ring-2 ring-blue-200' 
          : ''
        }
      `}
      style={{ 
        backgroundColor: actuallyCollapsed ? color : `${color}40`,
        minWidth: actuallyCollapsed ? '180px' : '160px',
        minHeight: actuallyCollapsed ? '100px' : '120px'
      }}
    >
      {/* Header with folder info */}
      <div className={`
        px-4 py-3 border-b border-slate-200 dark:border-slate-600/50
        backdrop-blur-sm flex items-center justify-between
        transition-colors duration-200
        ${actuallyCollapsed 
          ? 'bg-slate-100/80 dark:bg-slate-700/80 hover:bg-slate-200/80 dark:hover:bg-slate-600/80' 
          : 'bg-white/70 dark:bg-slate-800/70 hover:bg-white/80 dark:hover:bg-slate-800/80'
        }
        ${selected ? 'bg-blue-50/70' : ''}
      `}>
        <div className="flex items-center gap-2">
          <div className={`
            p-1 rounded-full transition-all duration-200
            ${actuallyCollapsed 
              ? 'bg-blue-100 dark:bg-blue-900/50 text-blue-600 dark:text-blue-400' 
              : 'bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-400'
            }
          `}>
            {actuallyCollapsed ? (
              <ChevronRight className="h-3 w-3" />
            ) : (
              <ChevronDown className="h-3 w-3" />
            )}
          </div>
          <Folder 
            className={`h-4 w-4 transition-colors duration-200 ${
              actuallyCollapsed 
                ? 'text-blue-600 dark:text-blue-400 fill-current' 
                : 'text-slate-600 dark:text-slate-400 fill-current'
            }`}
          />
          <span className={`text-sm font-medium truncate transition-colors duration-200 ${
            actuallyCollapsed 
              ? 'text-slate-800 dark:text-slate-200' 
              : 'text-slate-700 dark:text-slate-300'
          }`}>
            {label}
          </span>
        </div>
        
        <div className={`flex items-center gap-1 text-xs rounded-full px-2 py-1 transition-colors duration-200 ${
          actuallyCollapsed 
            ? 'text-blue-700 dark:text-blue-300 bg-blue-50/80 dark:bg-blue-900/50' 
            : 'text-slate-500 dark:text-slate-400 bg-white/80 dark:bg-slate-800/80'
        }`}>
          <Files className="h-3 w-3" />
          <span className="font-medium">{nodeCount}</span>
          <span className="opacity-60">{actuallyCollapsed ? 'files' : ''}</span>
        </div>
      </div>

      {/* Main content area */}
      <div className={`transition-all duration-200 ${
        actuallyCollapsed 
          ? 'p-3 min-h-[50px] flex items-center justify-center' 
          : 'p-2 min-h-[80px] flex items-center justify-center'
      }`}>
        {actuallyCollapsed ? (
          <div className="text-xs text-slate-500 dark:text-slate-400 text-center">
            <div className="flex items-center gap-1 justify-center">
              <div className="w-1.5 h-1.5 bg-blue-400 dark:bg-blue-500 rounded-full animate-pulse"></div>
              <span>Click to expand {nodeCount} files</span>
            </div>
          </div>
        ) : (
          <div className="text-xs text-slate-400 dark:text-slate-500 text-center opacity-50">
            <div>Cluster expanded</div>
            <div className="mt-1 opacity-60">Files are shown individually</div>
          </div>
        )}
      </div>

      {/* Invisible handles for connections between clusters */}
      <Handle 
        type="source" 
        position={Position.Right} 
        style={{ 
          opacity: 0, 
          width: 1, 
          height: 1,
          right: -1,
          top: '50%'
        }} 
      />
      <Handle 
        type="target" 
        position={Position.Left} 
        style={{ 
          opacity: 0, 
          width: 1, 
          height: 1,
          left: -1,
          top: '50%'
        }} 
      />
      
      {/* Additional handles for different directions */}
      <Handle 
        type="source" 
        position={Position.Bottom} 
        style={{ 
          opacity: 0, 
          width: 1, 
          height: 1,
          bottom: -1,
          left: '50%'
        }} 
      />
      <Handle 
        type="target" 
        position={Position.Top} 
        style={{ 
          opacity: 0, 
          width: 1, 
          height: 1,
          top: -1,
          left: '50%'
        }} 
      />

      {/* Selection indicator */}
      {selected && (
        <div className="absolute inset-0 rounded-2xl bg-blue-500/10 border-2 border-blue-500 pointer-events-none" />
      )}
    </div>
  );
});

GroupNode.displayName = 'GroupNode';

export default GroupNode;
