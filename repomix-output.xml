                        <span className="font-medium">
                          {Math.round((clusteringStats.clusteredNodes / (clusteringStats.clusteredNodes + clusteringStats.orphanedNodes)) * 100)}%
                        </span>
                      </div>
                      {getClusteringRecommendation(clusteringStats, clusterMinSize) && (
                        <div className="mt-2 p-2 bg-blue-50 dark:bg-blue-900/20 rounded border border-blue-200 dark:border-blue-800">
                          <div className="text-blue-700 dark:text-blue-300 font-medium">💡 Recommendation:</div>
                          <div className="text-blue-600 dark:text-blue-400 mt-1">
                            {getClusteringRecommendation(clusteringStats, clusterMinSize)?.message}
                          </div>
                          {getClusteringRecommendation(clusteringStats, clusterMinSize)?.action && (
                            <Button
                              size="sm"
                              variant="outline"
                              className="mt-2 h-6 text-xs border-blue-300 text-blue-700 hover:bg-blue-100 dark:border-blue-700 dark:text-blue-300 dark:hover:bg-blue-900/30"
                              onClick={() => {
                                const rec = getClusteringRecommendation(clusteringStats, clusterMinSize);
                                if (rec?.action?.type === 'adjust-minsize') {
                                  debouncedClusterMinSizeChange(rec.action.value);
                                }
                              }}
                            >
                              {getClusteringRecommendation(clusteringStats, clusterMinSize)?.action?.label}
                            </Button>
                          )}
                        </div>
                      )}
                    </div>
                  )}
                </div>
              )}
