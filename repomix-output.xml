export type LayoutDirection = 'TB' | 'LR';

export type LayoutOptions = {
  direction?: LayoutDirection;
  ranksep?: number;            // distance between levels
  nodesep?: number;            // distance between nodes in same level
  marginx?: number;            // left/right margin of graph
  marginy?: number;            // top/bottom margin of graph
};

export const DEFAULT_LAYOUT: Required<LayoutOptions> = {
  direction: 'TB',
  ranksep: 120, // Much more vertical space between levels
  nodesep: 80, // Much more horizontal space between nodes
  marginx: 50,
  marginy: 50,
};

// Adaptive settings based on graph size
export function getAdaptiveLayout(nodeCount: number): Required<LayoutOptions> {
  if (nodeCount > 200) {
    return {
      ...DEFAULT_LAYOUT,
      ranksep: 180, // Much more space untuk complex graphs
      nodesep: 120,
      marginx: 80,
      marginy: 80,
    };
  } else if (nodeCount > 100) {
    return {
      ...DEFAULT_LAYOUT,
      ranksep: 160,
      nodesep: 100,
      marginx: 70,
      marginy: 70,
    };
  } else if (nodeCount > 50) {
    return {
      ...DEFAULT_LAYOUT,
      ranksep: 140,
      nodesep: 90,
      marginx: 60,
      marginy: 60,
    };
  }
  return DEFAULT_LAYOUT;
}

// Debounce utility for layout controls
export function debounce<T extends (...args: any[]) => void>(
  func: T,
  wait: number
): (...args: Parameters<T>) => void {
  let timeout: NodeJS.Timeout;
  return (...args: Parameters<T>) => {
    clearTimeout(timeout);
    timeout = setTimeout(() => func(...args), wait);
  };
}
