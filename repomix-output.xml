import dagre from 'dagre';
import type { Edge, Node } from 'reactflow';
import { DEFAULT_LAYOUT, type LayoutOptions } from '@/config/layout';

// Convert center coordinates to top-left (React Flow expects top-left)
const toTopLeft = (x: number, y: number, w: number, h: number) => ({ 
  x: x - w / 2, 
  y: y - h / 2 
});

export function layoutGraph(
  nodes: Node[],
  edges: Edge[],
  opts?: LayoutOptions,
) {
  const g = new dagre.graphlib.Graph();
  const options = { ...DEFAULT_LAYOUT, ...(opts || {}) };
  
  g.setGraph({
    rankdir: options.direction,
    ranksep: options.ranksep,
    nodesep: options.nodesep,
    marginx: options.marginx,
    marginy: options.marginy,
    // Improved settings untuk better edge routing dan node distribution
    acyclicer: 'greedy', // Better for removing cycles
    ranker: 'network-simplex', // Better ranking algorithm untuk cleaner layouts
    align: 'UL', // Align nodes untuk more consistent positioning
    edgesep: 20, // Separation between edge segments
    compound: false, // Disable compound nodes untuk simpler layout
  });
  
  g.setDefaultEdgeLabel(() => ({
    minlen: 2, // Minimum length untuk better edge spacing
    weight: 1, // Equal weight untuk all edges
    labeloffset: 10, // Offset untuk edge labels
    labelpos: 'c' // Center position untuk labels
  }));

  // Use actual node dimensions if available, otherwise fallback to larger defaults
  nodes.forEach((n) => {
    const width = (n.width ?? (n.data?.width as number)) || 180; // Increased default width
    const height = (n.height ?? (n.data?.height as number)) || 60; // Increased default height
    g.setNode(n.id, { width, height });
  });

  edges.forEach((e) => {
    g.setEdge(e.source, e.target);
  });

  dagre.layout(g);

  // Create position map for efficient lookup
  const positionMap = new Map<string, { x: number; y: number }>();
  g.nodes().forEach((id) => {
    const { x, y, width, height } = g.node(id);
    positionMap.set(id, toTopLeft(x, y, width, height));
  });

  const layoutedNodes = nodes.map((n) => ({
    ...n,
    position: positionMap.get(n.id) ?? n.position,
  }));

  return { nodes: layoutedNodes, edges };
}
