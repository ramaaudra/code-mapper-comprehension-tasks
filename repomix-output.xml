import { memo } from 'react';
import { BaseEdge, getBezierPath, getStraightPath, getSmoothStepPath, type EdgeProps } from 'reactflow';

const CustomEdge = memo(({ 
  id, 
  sourceX, 
  sourceY, 
  targetX, 
  targetY, 
  sourcePosition, 
  targetPosition, 
  style = {}, 
  data,
  markerEnd 
}: EdgeProps) => {
  // Calculate distance dan direction untuk better routing
  const dx = Math.abs(targetX - sourceX);
  const dy = Math.abs(targetY - sourceY);
  const distance = Math.sqrt(dx * dx + dy * dy);
  
  // Determine if edge is going left-to-right or right-to-left
  const isForward = targetX > sourceX;
  const verticalOffset = Math.abs(targetY - sourceY);
  
  let edgePath: string;
  
  // Use improved routing logic untuk better edge separation
  if (distance < 80) {
    // Very short distances: straight line
    [edgePath] = getStraightPath({ sourceX, sourceY, targetX, targetY });
  } else if (verticalOffset < 50 && dx > 100) {
    // Horizontal connections: use smooth step dengan offset
    const offset = isForward ? 20 : -20; // Add horizontal offset untuk avoid overlap
    [edgePath] = getSmoothStepPath({
      sourceX: sourceX + offset,
      sourceY,
      sourcePosition,
      targetX: targetX - offset,
      targetY,
      targetPosition,
      borderRadius: 12, // Larger radius untuk smoother curves
    });
  } else {
    // Vertical or diagonal connections: bezier dengan controlled curvature
    let curvature = 0.25; // Base curvature
    
    // Adjust curvature based on direction dan distance
    if (distance > 300) curvature = 0.15; // Less curve untuk long distances
    if (verticalOffset > 150) curvature = 0.3; // More curve untuk vertical separation
    if (!isForward) curvature *= 1.5; // More curve untuk backward connections
    
    [edgePath] = getBezierPath({
      sourceX,
      sourceY,
      sourcePosition,
      targetX,
      targetY,
      targetPosition,
      curvature,
    });
  }

  return (
    <>
      <BaseEdge 
        id={id}
        path={edgePath} 
        style={{
          ...style,
          strokeLinecap: 'round',
          strokeLinejoin: 'round',
        }}
        markerEnd={markerEnd}
      />
      {/* Edge label untuk aggregated edges */}
      {data?.weight > 1 && (
        <text>
          <textPath
            href={`#${id}`}
            style={{ fontSize: '9px', fill: '#6b7280', fontWeight: '500' }}
            startOffset="50%"
            textAnchor="middle"
          >
            {data.weight}
          </textPath>
        </text>
      )}
    </>
  );
});

CustomEdge.displayName = 'CustomEdge';

export default CustomEdge;
</file>

