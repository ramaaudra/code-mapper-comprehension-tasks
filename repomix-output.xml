import { forwardRef, useCallback, useEffect, useImperativeHandle, useMemo, useState, memo } from 'react';
import ReactFlow, { Background, Controls, MiniMap, type Node, type Edge, type NodeProps, Handle, Position, useReactFlow } from 'reactflow';
import 'reactflow/dist/style.css';
import { layoutGraph } from '@/lib/layout';
import { shouldUseClustering } from '@/lib/clusterLayout';
import { simpleLayoutWithClusters } from '@/lib/simpleClusterLayout';
import { getClusteringStats, buildClusters } from '@/lib/cluster';
import { DEFAULT_LAYOUT, getAdaptiveLayout, type LayoutDirection } from '@/config/layout';
import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from '@/components/ui/tooltip';
import GroupNode from '@/components/nodes/GroupNode';
import CustomEdge from '@/components/edges/CustomEdge';

// Custom Node Component with hover effects
const CustomNode = memo(({ data, selected }: NodeProps) => {
  const [isHovered, setIsHovered] = useState(false);
  
  const handleMouseEnter = useCallback(() => setIsHovered(true), []);
  const handleMouseLeave = useCallback(() => setIsHovered(false), []);
  
  return (
    <TooltipProvider>
      <Tooltip>
        <TooltipTrigger asChild>
          <div
            className={`
              px-4 py-2 rounded-2xl border-2 bg-white dark:bg-gray-900 shadow-lg relative
              transition-all duration-200 hover:shadow-xl hover:scale-105
              text-sm font-medium cursor-pointer min-w-[120px] text-center
              ${selected ? 'border-blue-500 shadow-blue-200' : isHovered ? 'border-gray-400' : 'border-gray-200'}
            `}
            onMouseEnter={handleMouseEnter}
            onMouseLeave={handleMouseLeave}
          >
            {data.isHighImpact && (
              <div className={`absolute -top-1 -right-1 w-4 h-4 rounded-full flex items-center justify-center text-xs font-bold ${
                data.impactLevel === 'critical' ? 'bg-red-500 text-white' :
                data.impactLevel === 'high' ? 'bg-orange-500 text-white' :
                'bg-yellow-500 text-white'
              }`}>
                {data.indegree}
              </div>
            )}
            {data.basename}
            <Handle type="target" position={Position.Left} className="w-2 h-2" />
            <Handle type="source" position={Position.Right} className="w-2 h-2" />
          </div>
        </TooltipTrigger>
        <TooltipContent className="max-w-xs">
          <div className="space-y-1">
            <div className="font-medium">{data.basename}</div>
            <div className="text-xs opacity-75 font-mono break-all">{data.label}</div>
            <div className="text-xs">Size: {data.size ? `${(data.size / 1024).toFixed(1)}KB` : 'Unknown'}</div>
            {data.isHighImpact && (
              <div className={`text-xs px-2 py-1 rounded-full text-center font-medium ${
                data.impactLevel === 'critical' ? 'bg-red-100 text-red-800 dark:bg-red-900/50 dark:text-red-300' :
                data.impactLevel === 'high' ? 'bg-orange-100 text-orange-800 dark:bg-orange-900/50 dark:text-orange-300' :
                'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/50 dark:text-yellow-300'
              }`}>
                🔥 High Impact ({data.indegree} dependencies)
              </div>
            )}
          </div>
        </TooltipContent>
      </Tooltip>
    </TooltipProvider>
  );
});

CustomNode.displayName = 'CustomNode';

// Move nodeTypes and edgeTypes outside component for better performance
const nodeTypes = {
  custom: CustomNode,
  group: GroupNode,
};

const edgeTypes = {
  default: CustomEdge,
  custom: CustomEdge,
};

interface GraphViewProps {
  data: any;
  query: string;
  showDynamicImports?: boolean;
  onNodeClick?: (node: any) => void;
  direction?: LayoutDirection;
  ranksep?: number;
  nodesep?: number;
  // Clustering props
  useClustering?: boolean;
  clusterDepth?: number;
  clusterMinSize?: number;
  onClusteringStatsChange?: (stats: any) => void;
}

export interface GraphViewRef {
  fitView: () => void;
}

const GraphView = forwardRef<GraphViewRef, GraphViewProps>(({ 
  data, 
  query, 
  showDynamicImports = true, 
  onNodeClick,
  direction = 'TB',
  ranksep,
  nodesep,
  useClustering = false,
  clusterDepth = 1,
  clusterMinSize = 2,
  onClusteringStatsChange
}, ref) => {
  const rf = useReactFlow();
  const [graph, setGraph] = useState<{ nodes: Node[]; edges: Edge[] }>({ nodes: [], edges: [] });
  const [isLayouted, setIsLayouted] = useState(false);
  const [collapsedClusterIds, setCollapsedClusterIds] = useState<Set<string>>(new Set());
  const [autoCollapseInitialized, setAutoCollapseInitialized] = useState(false);

  // Expose fitView function to parent via ref
  useImperativeHandle(ref, () => ({
    fitView: () => rf.fitView({ padding: 0.2 })
  }), [rf]);

  // Memoize path labels for clustering
  const pathLabels = useMemo(() => {
    if (!data) return {};
    return Object.fromEntries(
      data.nodes.map((n: any) => [n.id, n.label || ''])
    );
  }, [data]);

  // Memoize layout options for stability with adaptive settings
  const layoutOptions = useMemo(() => {
    const nodeCount = graph.nodes.length;
    const adaptiveDefaults = nodeCount > 50 ? getAdaptiveLayout(nodeCount) : DEFAULT_LAYOUT;
    
    return {
      ...adaptiveDefaults,
      direction,
      ...(ranksep && { ranksep }),
      ...(nodesep && { nodesep })
    };
  }, [direction, ranksep, nodesep, graph.nodes.length]);

  // Determine if clustering should be used and is beneficial
  const shouldCluster = useMemo(() => {
    return useClustering && shouldUseClustering(pathLabels, { 
      depth: clusterDepth, 
      minSize: clusterMinSize 
    });
  }, [useClustering, pathLabels, clusterDepth, clusterMinSize]);

  // Auto-collapse large clusters initially
  useEffect(() => {
    if (!shouldCluster || !pathLabels || autoCollapseInitialized) return;
    
    const labels = Object.entries(pathLabels).map(([id, pathLabel]) => ({ id, pathLabel }));
    const clusters = buildClusters(labels, { 
      depth: clusterDepth, 
      minSize: clusterMinSize 
    });
    
    // Auto-collapse clusters with more than 8 files for better initial view
    const largeClusters = clusters.filter(c => c.nodes.length > 8).map(c => c.id);
    if (largeClusters.length > 0) {
      setCollapsedClusterIds(new Set(largeClusters));
    }
    
    setAutoCollapseInitialized(true);
  }, [shouldCluster, pathLabels, clusterDepth, clusterMinSize, autoCollapseInitialized]);

  // 1) Build base nodes/edges with temporary positions
  const baseGraph = useMemo(() => {
    if (!data) return { nodes: [], edges: [] };
    const q = (query || '').toLowerCase();
    
    // Filter edges based on showDynamicImports
    const filteredEdges = showDynamicImports 
      ? data.edges 
      : data.edges.filter((e: any) => e.kind !== 'dynamic');
    
    // Create high impact files set for styling
    const highImpactFiles = new Set(data.issues?.highImpact?.map((item: any) => item.file) || []);
    const highImpactMap = new Map(
      (data.issues?.highImpact || []).map((item: any) => [item.file, item.indegree])
    );
    
    const nodes: Node[] = data.nodes.map((n: any) => {
      const isHighImpact = highImpactFiles.has(n.id);
      const indegreeValue = highImpactMap.get(n.id);
      const indegree: number = typeof indegreeValue === 'number' ? indegreeValue : 0;
      const isSearchMatch = n.label.toLowerCase().includes(q) || n.basename.toLowerCase().includes(q);
      
      // Determine node styling based on impact level
      let impactClass = '';
      if (isHighImpact) {
        if (indegree >= 3) {
          impactClass = 'ring-4 ring-red-500 ring-offset-2 shadow-lg shadow-red-200';
        } else if (indegree >= 2) {
          impactClass = 'ring-3 ring-orange-500 ring-offset-1 shadow-md shadow-orange-200';
        } else {
          impactClass = 'ring-2 ring-yellow-500 shadow-sm shadow-yellow-200';
        }
      }
      
      const searchClass = isSearchMatch ? 'ring-2 ring-blue-400' : '';
      const finalClass = isSearchMatch ? searchClass : impactClass;
      
      return {
        id: n.id,
        type: 'custom',
        data: { 
          label: n.label,          // relative path from backend
          basename: n.basename,    // basename for tooltip
          fullPath: n.id,         // full absolute path
          size: n.size,           // accurate file size in bytes
          isHighImpact,           // flag untuk high impact
          indegree,               // dependency count
          impactLevel: indegree >= 3 ? 'critical' : indegree >= 2 ? 'high' : 'medium'
        },
        // Temporary random position for initial render
        position: { x: Math.random() * 800, y: Math.random() * 600 },
        className: finalClass,
        style: isHighImpact ? {
          zIndex: 10, // High impact nodes di atas
          transform: indegree >= 2 ? 'scale(1.1)' : 'scale(1.05)' // Sedikit lebih besar
        } : undefined
      };
    });
    
    // Calculate importance of target nodes untuk edge weight
    const targetImportanceMap = new Map<string, number>();
    (data.issues?.highImpact || []).forEach((item: any) => {
      targetImportanceMap.set(item.file, item.indegree);
    });
    
    const edges: Edge[] = filteredEdges.map((e: any, i: number) => {
      const targetImportance = targetImportanceMap.get(e.target) || 0;
      
      // Calculate edge weight berdasarkan target importance
      const baseWidth = e.kind === 'dynamic' ? 3 : 2;
      const importanceBonus = targetImportance > 0 ? Math.min(targetImportance * 0.8, 3) : 0;
      const finalWidth = Math.max(baseWidth + importanceBonus, baseWidth);
      
      const strokeColor = e.kind === 'dynamic' ? '#f59e0b' : 
                          targetImportance >= 2 ? '#ef4444' : // Red untuk high impact targets
                          targetImportance >= 1 ? '#f97316' : // Orange untuk medium impact
                          '#6b7280';
      
      return { 
        id: String(i), 
        source: e.source, 
        target: e.target, 
        type: 'custom', // Menggunakan custom edge component
        markerEnd: {
          type: 'arrowclosed',
          width: 14,
          height: 14,
          color: strokeColor,
          strokeWidth: 1.5,
          orient: 'auto-start-reverse'
        }, 
        animated: e.kind === 'dynamic',
        style: {
          stroke: strokeColor,
          strokeWidth: Math.min(finalWidth, 4), // Max 4px untuk cleaner look
          strokeDasharray: e.kind === 'dynamic' ? '4 2' : undefined, // More subtle dash
          strokeLinecap: 'round',
          strokeLinejoin: 'round',
          opacity: e.kind === 'dynamic' ? 0.9 : 
                   targetImportance >= 2 ? 0.95 : // High impact sangat visible
                   targetImportance >= 1 ? 0.85 :
                   0.7, // Regular edges cukup visible
        },
        className: e.kind === 'dynamic' ? 'stroke-amber-500' : 
                   targetImportance >= 2 ? 'stroke-red-400' : 
                   targetImportance >= 1 ? 'stroke-orange-400' :
                   'stroke-gray-400',
        data: {
          isDynamic: e.kind === 'dynamic',
          originalKind: e.kind,
          targetImportance,
          finalWidth,
          weight: 1 // For consistent API
        }
      };
    });

    return { nodes, edges };
  }, [data, query, showDynamicImports]);

  // Set base graph when data changes
  useEffect(() => {
    setGraph(baseGraph);
    setIsLayouted(false);
    setAutoCollapseInitialized(false); // Reset auto-collapse for new data
    setCollapsedClusterIds(new Set()); // Reset collapsed clusters
  }, [baseGraph]);

  // 2) After nodes are measured by React Flow, re-layout with actual sizes
  useEffect(() => {
    if (!graph.nodes.length || isLayouted) return;
    
    // Wait for React Flow to measure node dimensions
    const layoutId = requestAnimationFrame(() => {
      const measuredNodes = rf.getNodes(); // Contains width/height
      
      // Merge measured dimensions back into our nodes
      const nodesWithDimensions = graph.nodes.map(n => {
        const measured = measuredNodes.find(m => m.id === n.id);
        return measured ? { ...n, width: measured.width, height: measured.height } : n;
      });
      
      // Now layout with accurate dimensions using clustering if enabled
      const layoutedGraph = shouldCluster
        ? simpleLayoutWithClusters(
            nodesWithDimensions as Node[],
            graph.edges,
            pathLabels,
            {
              depth: clusterDepth,
              minSize: clusterMinSize,
              layoutOptions,
              collapsedClusterIds
            }
          )
        : layoutGraph(
            nodesWithDimensions as Node[],
            graph.edges,
            layoutOptions
          );

      // Update clustering statistics if callback provided
      if (shouldCluster && onClusteringStatsChange) {
        const labels = Object.entries(pathLabels).map(([id, pathLabel]) => ({ id, pathLabel }));
        const clusters = buildClusters(labels, { 
          depth: clusterDepth, 
          minSize: clusterMinSize 
        });
        const stats = getClusteringStats(clusters, nodesWithDimensions.length);
        onClusteringStatsChange(stats);
      }
      
      setGraph(layoutedGraph);
      
      // Fit view first, then show edges with slight delay for perfect positioning
      requestAnimationFrame(() => {
        rf.fitView({ padding: 0.2 });
        // Small delay to ensure all nodes are properly positioned before showing edges
        setTimeout(() => {
          setIsLayouted(true);
        }, 50);
      });
    });
    
    return () => cancelAnimationFrame(layoutId);
  }, [graph.nodes, graph.edges, rf, isLayouted, layoutOptions, shouldCluster, pathLabels, clusterDepth, clusterMinSize, onClusteringStatsChange, collapsedClusterIds]);

  // Re-layout when layout options or clustering settings change
  useEffect(() => {
    if (!isLayouted) return;
    
    const relayoutId = requestAnimationFrame(() => {
      const currentNodes = rf.getNodes() as Node[];
      
      const layoutedGraph = shouldCluster
        ? simpleLayoutWithClusters(
            currentNodes,
            graph.edges,
            pathLabels,
            {
              depth: clusterDepth,
              minSize: clusterMinSize,
              layoutOptions,
              collapsedClusterIds
            }
          )
        : layoutGraph(
            currentNodes,
            graph.edges,
            layoutOptions
          );
      
      // Update clustering statistics for re-layout
      if (shouldCluster && onClusteringStatsChange) {
        const labels = Object.entries(pathLabels).map(([id, pathLabel]) => ({ id, pathLabel }));
        const clusters = buildClusters(labels, { 
          depth: clusterDepth, 
          minSize: clusterMinSize 
        });
        const stats = getClusteringStats(clusters, currentNodes.length);
        onClusteringStatsChange(stats);
      }
      
      setGraph(layoutedGraph);
      requestAnimationFrame(() => {
        rf.fitView({ padding: 0.2 });
        // Ensure edges appear after fit view is complete
        setTimeout(() => {
          if (!isLayouted) setIsLayouted(true);
        }, 50);
      });
    });
    
    return () => cancelAnimationFrame(relayoutId);
  }, [layoutOptions, shouldCluster, pathLabels, clusterDepth, clusterMinSize, rf, isLayouted, graph.edges, onClusteringStatsChange, collapsedClusterIds]);

  // Auto-center on search results when query changes
  useEffect(() => {
    if (!query.trim() || !isLayouted) return;
    
    const searchTerm = query.toLowerCase();
    const matchingNodes = rf.getNodes().filter(node => {
      const basename = node.data?.basename?.toLowerCase() || '';
      const label = node.data?.label?.toLowerCase() || '';
      return basename.includes(searchTerm) || label.includes(searchTerm);
    });
    
    if (matchingNodes.length > 0) {
      // Focus on the first matching node with smooth transition
      const firstMatch = matchingNodes[0];
      rf.setCenter(firstMatch.position.x + (firstMatch.width || 160) / 2, 
                   firstMatch.position.y + (firstMatch.height || 48) / 2, 
                   { zoom: 1.2, duration: 800 });
    }
  }, [query, isLayouted, rf]);

  if (!data) {
    return (
      <div className="h-full flex items-center justify-center bg-gray-50 dark:bg-gray-900">
        <div className="text-center space-y-4 p-8">
          <div className="text-6xl opacity-20">📊</div>
          <div className="text-lg font-medium text-gray-600 dark:text-gray-400">
            No data yet
          </div>
          <div className="text-sm text-gray-500 dark:text-gray-500">
            Open the sidebar and analyze a project to see the dependency graph
          </div>
        </div>
      </div>
    );
  }
  
  const handleNodeClick = useCallback((_event: React.MouseEvent, node: any) => {
    // Handle cluster collapse/expand
    if (node.type === 'group' && !node.data?.isBackground) {
      const clusterId = node.id.replace('cluster-', '');
      
      setCollapsedClusterIds(prev => {
        const newSet = new Set(prev);
        if (newSet.has(clusterId)) {
          newSet.delete(clusterId); // Expand cluster
        } else {
          newSet.add(clusterId); // Collapse cluster
        }
        return newSet;
      });
      
      // Force re-layout after state change
      setIsLayouted(false);
      return;
    }
    
    if (onNodeClick) {
      onNodeClick(node);
    }
  }, [onNodeClick]);

  // toggleCluster function removed as it's redundant with handleNodeClick logic
  
  return (
    <div className="h-full bg-gray-50 dark:bg-gray-900 relative">
      {/* Layout calculation loading indicator */}
      {!isLayouted && graph.nodes.length > 0 && (
        <div className="absolute inset-0 bg-gray-50/80 dark:bg-gray-900/80 backdrop-blur-sm z-50 flex items-center justify-center">
          <div className="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-xl border border-slate-200 dark:border-slate-700">
            <div className="flex items-center gap-3">
              <div className="animate-spin rounded-full h-6 w-6 border-b-2 border-blue-600"></div>
              <div className="text-slate-700 dark:text-slate-300 font-medium">
                Calculating layout...
              </div>
            </div>
            <div className="text-xs text-slate-500 dark:text-slate-400 mt-2 text-center">
              Positioning {graph.nodes.length} nodes
            </div>
          </div>
        </div>
      )}
      
      <ReactFlow 
        nodes={graph.nodes} 
        edges={isLayouted ? graph.edges : []} // Hide edges until layout complete
        nodeTypes={nodeTypes}
        edgeTypes={edgeTypes}
        onNodeClick={handleNodeClick}
        fitView={!isLayouted}  // Only fitView on initial render
        fitViewOptions={{ padding: 0.2 }}
        minZoom={0.1}
        maxZoom={2}
        defaultViewport={{ x: 0, y: 0, zoom: 1 }}
        className="bg-gray-50 dark:bg-gray-900"
      >
        <Background 
          gap={20} 
          size={1} 
          className="opacity-30" 
        />
        <Controls 
          className="bg-white dark:bg-gray-800 shadow-lg rounded-2xl border"
          showZoom={true}
          showFitView={true}
          showInteractive={false}
        />
        <MiniMap 
          className="bg-white dark:bg-gray-800 border rounded-2xl shadow-lg" 
          pannable 
          zoomable
          nodeColor="#6b7280"
          maskColor="rgb(0, 0, 0, 0.1)"
        />
      </ReactFlow>
    </div>
  );
});

GraphView.displayName = 'GraphView';
export default GraphView;
</file>

<file path="src/components/IssuesPanel.tsx">
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogTrigger } from '@/components/ui/dialog';
import { AlertTriangle, FileX, TrendingUp } from 'lucide-react';

interface IssuesPanelProps {
  data: any;
}

export default function IssuesPanel({ data }: IssuesPanelProps) {
  if (!data?.issues) {
    return (
      <Card>
        <CardHeader>
          <CardTitle className="text-sm font-medium">Issues</CardTitle>
        </CardHeader>
        <CardContent>
          <p className="text-sm text-muted-foreground">No data available</p>
        </CardContent>
      </Card>
    );
  }

  const { circularDependencies, orphans, highImpact } = data.issues;

  return (
    <Card>
      <CardHeader>
        <CardTitle className="text-sm font-medium">Issues</CardTitle>
      </CardHeader>
      <CardContent className="space-y-4">
        {/* Circular Dependencies */}
        <div className="flex items-center justify-between">
          <div className="flex items-center gap-2">
            <AlertTriangle className="h-4 w-4 text-orange-500" />
            <span className="text-sm text-muted-foreground">Cycles</span>
          </div>
          <Dialog>
            <DialogTrigger asChild>
              <Badge 
                variant={circularDependencies.length > 0 ? "destructive" : "secondary"}
                className="cursor-pointer hover:opacity-80"
              >
                {circularDependencies.length}
              </Badge>
            </DialogTrigger>
            <DialogContent className="max-w-2xl">
              <DialogHeader>
                <DialogTitle>Circular Dependencies ({circularDependencies.length})</DialogTitle>
              </DialogHeader>
              <div className="max-h-96 overflow-y-auto space-y-2">
                {circularDependencies.length === 0 ? (
                  <p className="text-sm text-muted-foreground">No circular dependencies found.</p>
                ) : (
                  circularDependencies.map((cycle: string[], index: number) => (
                    <div key={index} className="border rounded p-3">
                      <p className="text-sm font-medium mb-2">Cycle {index + 1}:</p>
                      <div className="space-y-1">
                        {cycle.map((file, fileIndex) => (
                          <div key={fileIndex} className="text-xs font-mono bg-muted p-1 rounded">
                            {fileIndex + 1}. {file.split('/').pop()}
                          </div>
                        ))}
                      </div>
                    </div>
                  ))
                )}
              </div>
            </DialogContent>
          </Dialog>
        </div>

        {/* Orphaned Files */}
        <div className="flex items-center justify-between">
          <div className="flex items-center gap-2">
            <FileX className="h-4 w-4 text-gray-500" />
            <span className="text-sm text-muted-foreground">Orphans</span>
          </div>
          <Dialog>
            <DialogTrigger asChild>
              <Badge 
                variant={orphans.length > 0 ? "outline" : "secondary"}
                className="cursor-pointer hover:opacity-80"
              >
                {orphans.length}
              </Badge>
            </DialogTrigger>
            <DialogContent className="max-w-2xl">
              <DialogHeader>
                <DialogTitle>Orphaned Files ({orphans.length})</DialogTitle>
              </DialogHeader>
              <div className="max-h-96 overflow-y-auto">
                {orphans.length === 0 ? (
                  <p className="text-sm text-muted-foreground">No orphaned files found.</p>
                ) : (
                  <div className="space-y-1">
                    {orphans.map((file: string, index: number) => (
                      <div key={index} className="text-xs font-mono bg-muted p-2 rounded">
                        {file.split('/').pop()}
                        <div className="text-xs text-muted-foreground mt-1 truncate">
                          {file}
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </DialogContent>
          </Dialog>
        </div>

        {/* High Impact Files */}
        <div className="flex items-center justify-between">
          <div className="flex items-center gap-2">
            <TrendingUp className="h-4 w-4 text-blue-500" />
            <span className="text-sm text-muted-foreground">High Impact</span>
          </div>
          <Dialog>
            <DialogTrigger asChild>
              <Badge 
                variant="default"
                className="cursor-pointer hover:opacity-80"
              >
                {highImpact.length}
              </Badge>
            </DialogTrigger>
            <DialogContent className="max-w-2xl">
              <DialogHeader>
                <DialogTitle>High Impact Files ({highImpact.length})</DialogTitle>
              </DialogHeader>
              <div className="max-h-96 overflow-y-auto">
                {highImpact.length === 0 ? (
                  <p className="text-sm text-muted-foreground">No high impact files found.</p>
                ) : (
                  <div className="space-y-2">
                    {highImpact.map((item: { file: string; indegree: number }, index: number) => (
                      <div key={index} className="border rounded p-3">
                        <div className="flex items-center justify-between mb-2">
                          <span className="text-sm font-medium">{item.file.split('/').pop()}</span>
                          <Badge variant="secondary">{item.indegree} deps</Badge>
                        </div>
                        <div className="text-xs text-muted-foreground truncate">
                          {item.file}
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </DialogContent>
          </Dialog>
        </div>
      </CardContent>
    </Card>
  );
}
</file>

<file path="src/components/LayoutControls.tsx">
import { useState } from 'react';
import { Button } from '@/components/ui/button';
import { Switch } from '@/components/ui/switch';
import { Slider } from '@/components/ui/slider';
import { Label } from '@/components/ui/label';
import { Card } from '@/components/ui/card';
import { Sheet, SheetContent, SheetHeader, SheetTitle, SheetTrigger } from '@/components/ui/sheet';
import { Settings, RotateCcw, Eye, EyeOff, Layers, FolderTree } from 'lucide-react';
import { type LayoutDirection, debounce } from '@/config/layout';

interface LayoutControlsProps {
  direction: LayoutDirection;
  onDirectionChange: (direction: LayoutDirection) => void;
  ranksep: number;
  onRanksepChange: (value: number) => void;
  nodesep: number;
  onNodesepChange: (value: number) => void;
  showDynamicImports: boolean;
  onShowDynamicImportsChange: (show: boolean) => void;
  onFitView: () => void;
  // Clustering controls
  useClustering: boolean;
  onUseClusteringChange: (use: boolean) => void;
  clusterDepth: number;
  onClusterDepthChange: (depth: number) => void;
  clusterMinSize: number;
  onClusterMinSizeChange: (size: number) => void;
  clusteringStats?: {
    clusterCount: number;
    clusteredNodes: number;
    orphanedNodes: number;
  };
}

export default function LayoutControls({
  direction,
  onDirectionChange,
  ranksep,
  onRanksepChange,
  nodesep,
  onNodesepChange,
  showDynamicImports,
  onShowDynamicImportsChange,
  onFitView,
  useClustering,
  onUseClusteringChange,
  clusterDepth,
  onClusterDepthChange,
  clusterMinSize,
  onClusterMinSizeChange,
  clusteringStats
}: LayoutControlsProps) {
  const [isOpen, setIsOpen] = useState(false);

  // Debounce slider changes to avoid too frequent re-layouts
  const debouncedRanksepChange = debounce(onRanksepChange, 200);
  const debouncedNodesepChange = debounce(onNodesepChange, 200);
  const debouncedClusterDepthChange = debounce(onClusterDepthChange, 300);
  const debouncedClusterMinSizeChange = debounce(onClusterMinSizeChange, 300);

  return (
    <Sheet open={isOpen} onOpenChange={setIsOpen}>
      <SheetTrigger asChild>
        <Button 
          variant="outline" 
          size="icon"
          className="absolute top-4 right-4 z-10 bg-white dark:bg-gray-800 shadow-lg hover:shadow-xl transition-shadow"
        >
          <Settings className="h-4 w-4" />
        </Button>
      </SheetTrigger>
      <SheetContent className="w-80 sm:w-96">
        <SheetHeader>
          <SheetTitle className="flex items-center gap-2">
            <Settings className="h-5 w-5" />
            Layout Controls
          </SheetTitle>
        </SheetHeader>
        
        <div className="space-y-6 pt-6">
          {/* Layout Direction */}
          <Card className="p-4">
            <h3 className="text-sm font-medium mb-3">Layout Direction</h3>
            <div className="flex gap-2">
              <Button
                variant={direction === 'TB' ? 'default' : 'outline'}
                size="sm"
                onClick={() => onDirectionChange('TB')}
                className="flex-1"
              >
                ↓ Top-Bottom
              </Button>
              <Button
                variant={direction === 'LR' ? 'default' : 'outline'}
                size="sm"
                onClick={() => onDirectionChange('LR')}
                className="flex-1"
              >
                → Left-Right
              </Button>
            </div>
          </Card>

          {/* Spacing Controls */}
          <Card className="p-4">
            <h3 className="text-sm font-medium mb-4">Spacing</h3>
            
            <div className="space-y-4">
              {/* Rank Separation */}
              <div className="space-y-2">
                <div className="flex justify-between">
                  <Label htmlFor="ranksep" className="text-sm">
                    Level Distance
                  </Label>
                  <span className="text-xs text-muted-foreground">
                    {ranksep}px
                  </span>
                </div>
                <Slider
                  id="ranksep"
                  min={50}
                  max={200}
                  step={10}
                  value={[ranksep]}
                  onValueChange={(values) => debouncedRanksepChange(values[0])}
                  className="w-full"
                />
              </div>

              {/* Node Separation */}
              <div className="space-y-2">
                <div className="flex justify-between">
                  <Label htmlFor="nodesep" className="text-sm">
                    Node Distance
                  </Label>
                  <span className="text-xs text-muted-foreground">
                    {nodesep}px
                  </span>
                </div>
                <Slider
                  id="nodesep"
                  min={20}
                  max={120}
                  step={10}
                  value={[nodesep]}
                  onValueChange={(values) => debouncedNodesepChange(values[0])}
                  className="w-full"
                />
              </div>
            </div>
          </Card>

          {/* Clustering Controls */}
          <Card className="p-4">
            <h3 className="text-sm font-medium mb-4 flex items-center gap-2">
              <FolderTree className="h-4 w-4" />
              Folder Clustering
            </h3>
            
            {/* Clustering Toggle */}
            <div className="space-y-4">
              <div className="flex items-center justify-between">
                <div className="space-y-1">
                  <Label className="text-sm flex items-center gap-2">
                    <Layers className="h-4 w-4" />
                    Group by Folders
                  </Label>
                  <p className="text-xs text-muted-foreground">
                    Organize files into folder groups
                  </p>
                </div>
                <Switch
                  checked={useClustering}
                  onCheckedChange={onUseClusteringChange}
                />
              </div>

              {/* Clustering Settings - only show when enabled */}
              {useClustering && (
                <div className="space-y-4 border-t pt-4">
                  {/* Cluster Depth */}
                  <div className="space-y-2">
                    <div className="flex justify-between">
                      <Label className="text-sm">
                        Folder Depth
                      </Label>
                      <span className="text-xs text-muted-foreground">
                        {clusterDepth} level{clusterDepth > 1 ? 's' : ''}
                      </span>
                    </div>
                    <div className="flex gap-1">
                      {[1, 2, 3].map(depth => (
                        <Button
                          key={depth}
                          variant={clusterDepth === depth ? 'default' : 'outline'}
                          size="sm"
                          onClick={() => debouncedClusterDepthChange(depth)}
                          className="flex-1 text-xs"
                        >
                          {depth}
                        </Button>
                      ))}
                    </div>
                  </div>

                  {/* Minimum Cluster Size */}
                  <div className="space-y-2">
                    <div className="flex justify-between">
                      <Label className="text-sm">
                        Min Files per Folder
                      </Label>
                      <span className="text-xs text-muted-foreground">
                        {clusterMinSize} files
                      </span>
                    </div>
                    <Slider
                      min={2}
                      max={8}
                      step={1}
