<file path="src/lib/simpleClusterLayout.ts">
import type { Edge, Node } from 'reactflow';
import { layoutGraph } from './layout';
import { buildClusters, createNodeClusterMap, type ClusterOptions } from './cluster';
import { type LayoutOptions, DEFAULT_LAYOUT, type LayoutDirection } from '@/config/layout';

export interface SimpleClusterLayoutOptions extends ClusterOptions {
  padding?: number;
  gap?: number;
  clusterGap?: number;
  layoutOptions?: LayoutOptions;
  collapsedClusterIds?: Set<string>;
}

/**
 * Simple clustering approach that treats all nodes as independent
 * but renders cluster backgrounds for visual grouping
 */
export function simpleLayoutWithClusters(
  baseNodes: Node[],
  baseEdges: Edge[],
  pathLabels: Record<string, string>,
  options: SimpleClusterLayoutOptions = {}
): { nodes: Node[]; edges: Edge[] } {
  const {
    depth = 1,
    minSize = 2,
    padding = 24,
    clusterGap = 60,
    layoutOptions = DEFAULT_LAYOUT,
    collapsedClusterIds = new Set()
  } = options;

  // Build clusters
  const labels = baseNodes.map(n => ({
    id: n.id,
    pathLabel: pathLabels[n.id] || n.data?.label || ''
  }));
  
  const clusters = buildClusters(labels, { depth, minSize });
  const nodeToCluster = createNodeClusterMap(clusters);

  // If no meaningful clustering, use regular layout
  if (clusters.length === 0) {
    return layoutGraph(baseNodes, baseEdges, layoutOptions);
  }

  // Separate nodes into collapsed clusters and individual nodes
  const collapsedClusters = clusters.filter(c => collapsedClusterIds.has(c.id));
  const expandedClusters = clusters.filter(c => !collapsedClusterIds.has(c.id));
  
  // Nodes to layout: individual nodes from expanded clusters + collapsed cluster representatives
  const nodesToLayout: Node[] = [];
  const hiddenNodeIds = new Set<string>();
  
  // Add nodes from expanded clusters
  for (const cluster of expandedClusters) {
    const clusterNodes = baseNodes.filter(n => nodeToCluster[n.id] === cluster.id);
    nodesToLayout.push(...clusterNodes);
  }
  
  // Add individual nodes not in any cluster
  const unclusteredNodes = baseNodes.filter(n => !nodeToCluster[n.id]);
  nodesToLayout.push(...unclusteredNodes);
  
  // Create collapsed cluster representative nodes
  for (const cluster of collapsedClusters) {
    const clusterNodes = baseNodes.filter(n => nodeToCluster[n.id] === cluster.id);
    
    // Hide original cluster nodes
    clusterNodes.forEach(n => hiddenNodeIds.add(n.id));
    
    // Create a representative group node for the collapsed cluster
    nodesToLayout.push({
      id: `cluster-${cluster.id}`,
      type: 'group',
      data: {
        label: cluster.label,
        nodeCount: clusterNodes.length,
        color: cluster.color || '#f8fafc',
        isBackground: false,
        clusterId: cluster.id,
        collapsedNodes: clusterNodes.map(n => n.id),
        isCollapsed: true
      },
      position: { x: 0, y: 0 }, // Will be set by layout
      width: 180,
      height: 100
    });
  }

  // Create aggregated edges for collapsed clusters
  const aggregatedEdges = createAggregatedEdges(baseEdges, collapsedClusters, nodeToCluster, hiddenNodeIds);
  
  // Layout all nodes together first (simpler approach)
  const regularLayout = layoutGraph(nodesToLayout, aggregatedEdges, layoutOptions);
  
  // Calculate cluster bounding boxes based on contained nodes
  const clusterBounds = new Map<string, { 
    minX: number; minY: number; maxX: number; maxY: number; nodes: Node[]; center: { x: number; y: number } 
  }>();

  // Only create background bounds for expanded clusters
  for (const cluster of expandedClusters) {
    const clusterNodes = regularLayout.nodes.filter(n => nodeToCluster[n.id] === cluster.id);
    if (clusterNodes.length === 0) continue;

    const positions = clusterNodes.map(n => n.position);
    const widths = clusterNodes.map(n => n.width ?? 160);
    const heights = clusterNodes.map(n => n.height ?? 48);

    const xs = positions.map(p => p.x);
    const ys = positions.map(p => p.y);
    const maxXs = positions.map((p, i) => p.x + widths[i]);
    const maxYs = positions.map((p, i) => p.y + heights[i]);

    const minX = Math.min(...xs) - padding;
    const minY = Math.min(...ys) - padding;
    const maxX = Math.max(...maxXs) + padding;
    const maxY = Math.max(...maxYs) + padding;

    clusterBounds.set(cluster.id, {
      minX,
      minY,
      maxX,
      maxY,
      nodes: clusterNodes,
      center: { x: (minX + maxX) / 2, y: (minY + maxY) / 2 }
    });
  }

  // Separate clusters with consistent gaps to prevent overlapping
  separateClustersWithGaps(clusterBounds, clusterGap, layoutOptions.direction || 'TB');

  // Update node positions based on adjusted cluster bounds
  const adjustedNodes = regularLayout.nodes.map(node => {
    const clusterId = nodeToCluster[node.id];
    if (!clusterId) return node;
    
    const originalBounds = clusterBounds.get(clusterId);
    if (!originalBounds) return node;
    
    // Find the original cluster bounds before separation
    const originalClusterNodes = regularLayout.nodes.filter(n => nodeToCluster[n.id] === clusterId);
    const originalPositions = originalClusterNodes.map(n => n.position);
    
    const originalMinX = Math.min(...originalPositions.map(p => p.x)) - padding;
    const originalMinY = Math.min(...originalPositions.map(p => p.y)) - padding;
    
    // Calculate the offset to apply to this node
    const offsetX = originalBounds.minX - originalMinX;
    const offsetY = originalBounds.minY - originalMinY;
    
    return {
      ...node,
      position: {
        x: node.position.x + offsetX,
        y: node.position.y + offsetY
      }
    };
  });

  // Create background container nodes only for expanded clusters
  const backgroundNodes: Node[] = [];
  for (const cluster of expandedClusters) {
    const bounds = clusterBounds.get(cluster.id);
    if (!bounds) continue;

    const width = bounds.maxX - bounds.minX;
    const height = bounds.maxY - bounds.minY;

    backgroundNodes.push({
      id: `cluster-bg-${cluster.id}`,
      type: 'group',
      data: {
        label: cluster.label,
        width,
        height,
        nodeCount: bounds.nodes.length,
        color: cluster.color,
        isBackground: true
      },
      position: { x: bounds.minX, y: bounds.minY },
      style: {
        width,
        height,
        zIndex: -1, // Behind everything else
        pointerEvents: 'none' // Don't interfere with interactions
      },
      width,
      height,
      selectable: false,
      draggable: false,
      // These nodes are just visual backgrounds
      connectable: false
    });
  }

  // Use adjusted nodes instead of regular layout nodes
  const finalNodes = adjustedNodes || regularLayout.nodes;
  
  // Add cluster metadata to final nodes
  const enhancedNodes = finalNodes.map(n => ({
    ...n,
    data: {
      ...n.data,
      clusterId: nodeToCluster[n.id] || null,
      isClusteredNode: Boolean(nodeToCluster[n.id])
    }
  }));

  return {
    nodes: [...backgroundNodes, ...enhancedNodes],
    edges: aggregatedEdges.length > 0 ? aggregatedEdges : baseEdges
  };
}

/**
 * Separate cluster bounds to ensure consistent gaps between clusters
 * @param clusterBounds Map of cluster bounds to be modified in place
 * @param gap Minimum gap between clusters
 * @param direction Layout direction for determining separation axis
 */
function separateClustersWithGaps(
  clusterBounds: Map<string, { 
    minX: number; minY: number; maxX: number; maxY: number; nodes: Node[]; center: { x: number; y: number } 
  }>,
  gap: number,
  direction: LayoutDirection
): void {
  const clusters = Array.from(clusterBounds.entries());
  if (clusters.length <= 1) return;

  // Sort clusters by their position in the primary layout direction
  clusters.sort((a, b) => {
    if (direction === 'TB') {
      return a[1].center.y - b[1].center.y;
    } else {
      return a[1].center.x - b[1].center.x;
    }
  });

  // Adjust positions to ensure minimum gap
  for (let i = 1; i < clusters.length; i++) {
    const [currentId, currentBounds] = clusters[i];
    const [, prevBounds] = clusters[i - 1];
    
    let overlap = 0;
    let offset = 0;
    
    if (direction === 'TB') {
      // Check Y-axis overlap for top-bottom layout
      overlap = prevBounds.maxY - currentBounds.minY;
      if (overlap > -gap) {
        offset = overlap + gap;
        currentBounds.minY += offset;
        currentBounds.maxY += offset;
        currentBounds.center.y += offset;
      }
    } else {
      // Check X-axis overlap for left-right layout
      overlap = prevBounds.maxX - currentBounds.minX;
      if (overlap > -gap) {
        offset = overlap + gap;
        currentBounds.minX += offset;
        currentBounds.maxX += offset;
        currentBounds.center.x += offset;
      }
    }
    
    // Update the map with adjusted bounds
    clusterBounds.set(currentId, currentBounds);
  }
}

/**
 * Create aggregated edges for collapsed clusters
 * @param baseEdges Original edges between individual nodes
 * @param collapsedClusters List of collapsed clusters
 * @param nodeToCluster Mapping from node ID to cluster ID
 * @param hiddenNodeIds Set of node IDs that are hidden (in collapsed clusters)
 * @returns Aggregated edges with cluster representatives
 */
function createAggregatedEdges(
  baseEdges: Edge[],
  _collapsedClusters: { id: string; label: string; nodes: string[] }[],
  nodeToCluster: Record<string, string>,
  hiddenNodeIds: Set<string>
): Edge[] {
  // If no nodes are hidden, return original edges
  if (hiddenNodeIds.size === 0) {
    return baseEdges;
  }
  
  const aggregatedEdges: Edge[] = [];
  const edgeCountMap = new Map<string, { count: number; isDynamic: boolean; originalEdge: Edge }>();
  
  for (const edge of baseEdges) {
    let sourceId = edge.source;
    let targetId = edge.target;
    let needsAggregation = false;
    
    // Skip edges between hidden nodes within the same collapsed cluster
    if (hiddenNodeIds.has(sourceId) && hiddenNodeIds.has(targetId)) {
      const sourceCluster = nodeToCluster[sourceId];
      const targetCluster = nodeToCluster[targetId];
      if (sourceCluster === targetCluster) {
        continue; // Skip internal cluster edges
      }
    }
    
    // Replace hidden node IDs with their cluster representative IDs
    if (hiddenNodeIds.has(sourceId)) {
      const clusterName = nodeToCluster[sourceId];
      if (clusterName) {
        sourceId = `cluster-${clusterName}`;
        needsAggregation = true;
      }
    }
    if (hiddenNodeIds.has(targetId)) {
      const clusterName = nodeToCluster[targetId];
      if (clusterName) {
        targetId = `cluster-${clusterName}`;
        needsAggregation = true;
      }
    }
    
    // Skip self-loops
    if (sourceId === targetId) continue;
    
    // If no aggregation needed, keep original edge
    if (!needsAggregation) {
      aggregatedEdges.push(edge);
      continue;
    }
    
    const edgeKey = `${sourceId}->${targetId}`;
    const existing = edgeCountMap.get(edgeKey);
    const isDynamic = Boolean(edge.animated || edge.className?.includes('amber') || edge.style?.stroke?.includes('#f59e0b'));
    
    if (existing) {
      existing.count += 1;
      existing.isDynamic = existing.isDynamic || isDynamic;
    } else {
      edgeCountMap.set(edgeKey, { 
        count: 1, 
        isDynamic, 
        originalEdge: edge
      });
    }
  }
  
  // Create aggregated edges
  let edgeIndex = baseEdges.length;
  for (const [edgeKey, info] of edgeCountMap) {
    const [sourceId, targetId] = edgeKey.split('->');
    
    aggregatedEdges.push({
      id: `aggregated-${edgeIndex++}`,
      source: sourceId,
      target: targetId,
      type: 'default', // Consistent dengan GraphView
      markerEnd: { 
        type: 'arrowclosed' as any,
        width: 18, // Sedikit lebih besar untuk aggregated edges
        height: 18,
        color: info.isDynamic ? '#f59e0b' : '#6b7280'
      },
      animated: info.isDynamic,
      style: {
        stroke: info.isDynamic ? '#f59e0b' : '#6b7280',
        strokeWidth: Math.max(
          info.isDynamic ? 3 : 2.5, // Base width untuk aggregated
          Math.min(2 + Math.log(info.count), 6) // Max 6px untuk consistency
        ),
        strokeDasharray: info.isDynamic ? '4 2' : undefined, // Consistent dengan GraphView
        strokeLinecap: 'round',
        strokeLinejoin: 'round',
        opacity: info.isDynamic ? 0.9 : 0.8, // Consistent opacity dengan GraphView
      },
      label: info.count > 1 ? `${info.count}` : undefined,
      className: info.isDynamic ? 'stroke-amber-500' : 'stroke-gray-400',
      data: {
        weight: info.count,
        aggregated: true,
        kind: info.isDynamic ? 'dynamic' : 'static',
        isDynamic: info.isDynamic
      }
    });
  }
  
  return aggregatedEdges;
}
