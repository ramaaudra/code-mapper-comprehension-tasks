              <Button
                variant="ghost"
                size="sm"
                onClick={() => {
                  onDirectionChange('TB');
                  onRanksepChange(80);
                  onNodesepChange(40);
                  onShowDynamicImportsChange(true);
                  onUseClusteringChange(false);
                  onClusterDepthChange(1);
                  onClusterMinSizeChange(2);
                }}
                className="w-full text-xs"
              >
